#!/usr/bin/env bash
# scholar-search — Semantic Scholar Graph API (optional S2_API_KEY for higher limits).
# Usage: scholar-search "query" [--max N]
# JSON mode: scholar-search --json "query" [--max N]
set -euo pipefail

MAX=5
QUERY=""
JSON_MODE=0
S2_API_KEY="${S2_API_KEY:-}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --max) MAX="${2:?}"; shift 2 ;;
    --json) JSON_MODE=1; shift ;;
    -*) echo "Unknown option: $1" >&2; exit 1 ;;
    *)
      if [[ -z "$QUERY" ]]; then QUERY="$1"; else QUERY="$QUERY $1"; fi
      shift
      ;;
  esac
done

if [[ -z "$QUERY" ]]; then
  echo "Usage: scholar-search [--json] \"query\" [--max N]" >&2
  exit 1
fi

export QUERY MAX JSON_MODE S2_API_KEY

python3 - <<'PY'
import json
import os
import sys
import urllib.parse
import urllib.request

query = os.environ["QUERY"].strip()
max_r = min(max(int(os.environ.get("MAX", "5")), 1), 20)
json_mode = os.environ.get("JSON_MODE") == "1"
api_key = os.environ.get("S2_API_KEY", "").strip()

params = urllib.parse.urlencode({
    "query": query,
    "limit": max_r,
    "fields": "title,url,abstract,year,externalIds",
})
url = f"https://api.semanticscholar.org/graph/v1/paper/search?{params}"

req = urllib.request.Request(url, headers={"User-Agent": "sovereign-research/1.0"})
if api_key:
    req.add_header("x-api-key", api_key)

try:
    with urllib.request.urlopen(req, timeout=30) as resp:
        data = json.loads(resp.read().decode())
except Exception as e:
    if json_mode:
        print("[]")
        sys.exit(0)
    print(f"WARN: scholar API: {e}", file=sys.stderr)
    sys.exit(0)

hits = []
for p in data.get("data") or []:
    pid = p.get("paperId") or ""
    page_url = p.get("url") or (f"https://www.semanticscholar.org/paper/{pid}" if pid else "")
    if not page_url:
        continue
    hits.append({
        "title": (p.get("title") or "").strip(),
        "url": page_url,
        "snippet": (p.get("abstract") or "").strip()[:500],
        "retriever": "scholar",
    })

if json_mode:
    print(json.dumps(hits, ensure_ascii=False))
    sys.exit(0)

print(f">> scholar-search: {query} (max={max_r})")
if not api_key:
    print(">> note: set S2_API_KEY for higher rate limits")
print(f">> {len(hits)} result(s)\n")
for i, h in enumerate(hits, 1):
    print(f"{i}. {h['title']}")
    print(f"   {h['url']}")
    print(f"   retriever: scholar")
    if h.get("snippet"):
        print(f"   {h['snippet'][:400]}")
    print()
PY
