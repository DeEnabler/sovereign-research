#!/usr/bin/env bash
# deep-research — multi-query local web research → outbox report + sources.json
# Usage: deep-research "topic" [--depth quick|deep]
set -euo pipefail

ORIOSEARCH_URL="${ORIOSEARCH_URL:-${TAVILY_BASE_URL:-http://host.docker.internal:8000}}"
ORIOSEARCH_URL="${ORIOSEARCH_URL%/}"
API_KEY="${TAVILY_API_KEY:-local}"
OUTBOX_ROOT="${RESEARCH_OUTBOX:-/workspace/outbox}"
DEPTH="quick"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

TOPIC=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --depth) DEPTH="${2:?}"; shift 2 ;;
    -*) echo "Unknown option: $1" >&2; exit 1 ;;
    *)
      if [[ -z "$TOPIC" ]]; then TOPIC="$1"; else TOPIC="$TOPIC $1"; fi
      shift
      ;;
  esac
done

if [[ -z "$TOPIC" ]]; then
  echo "Usage: deep-research \"topic\" [--depth quick|deep]" >&2
  exit 1
fi

export ORIOSEARCH_URL API_KEY TOPIC DEPTH OUTBOX_ROOT SCRIPT_DIR
export S2_API_KEY="${S2_API_KEY:-}"
export GITHUB_TOKEN="${GITHUB_TOKEN:-}"

python3 - <<'PY'
import json
import os
import re
import subprocess
import sys
import urllib.request
from collections import Counter
from datetime import datetime, timezone

BASE = os.environ["ORIOSEARCH_URL"].rstrip("/")
API_KEY = os.environ.get("API_KEY", "local")
TOPIC = os.environ["TOPIC"].strip()
DEPTH = os.environ.get("DEPTH", "quick")
OUTBOX_ROOT = os.environ.get("OUTBOX_ROOT", "/workspace/outbox")
SCRIPT_DIR = os.environ.get("SCRIPT_DIR", "/usr/local/agent-bin")
MAX_TEXT = int(os.environ.get("EXTRACT_MAX_CHARS", "20000"))
MIN_CHARS = int(os.environ.get("EXTRACT_MIN_CHARS", "200"))

if DEPTH == "deep":
    sub_count, per_query = 6, 8
else:
    sub_count, per_query = 3, 5


def slugify(text: str) -> str:
    s = text.lower()
    s = re.sub(r"[^a-z0-9]+", "-", s)
    return s.strip("-")[:60] or "topic"


def post(path: str, payload: dict, timeout: int = 90) -> dict:
    data = json.dumps(payload).encode()
    req = urllib.request.Request(
        f"{BASE}{path}",
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        return json.loads(resp.read().decode())


def plan_queries(topic: str, n: int) -> list[str]:
    base = [
        topic,
        f"{topic} latest developments 2026",
        f"{topic} comparison benchmarks",
        f"{topic} open source self hosted",
        f"{topic} limitations criticism",
        f"{topic} best practices architecture",
    ]
    return base[:n]


def search(query: str, limit: int) -> list[dict]:
    try:
        data = post(
            "/search",
            {
                "api_key": API_KEY,
                "query": query,
                "max_results": limit,
                "search_depth": "advanced" if DEPTH == "deep" else "basic",
            },
        )
    except Exception as e:
        print(f"WARN: search failed for {query!r}: {e}", file=sys.stderr)
        return []
    hits = []
    for r in data.get("results") or []:
        url = (r.get("url") or "").strip()
        if not url:
            continue
        hits.append({
            "url": url,
            "title": (r.get("title") or "").strip(),
            "snippet": (r.get("content") or r.get("snippet") or "").strip()[:800],
            "query": query,
            "retriever": "web",
        })
    return hits


def run_retriever(script: str, query: str, limit: int) -> list[dict]:
    path = os.path.join(SCRIPT_DIR, script)
    if not os.path.isfile(path):
        return []
    try:
        out = subprocess.run(
            [path, "--json", query, "--max", str(limit)],
            capture_output=True,
            text=True,
            timeout=45,
            check=False,
        )
        if out.returncode != 0 and not out.stdout.strip():
            print(f"WARN: {script} failed: {out.stderr[:200]}", file=sys.stderr)
            return []
        raw = out.stdout.strip()
        if not raw:
            return []
        items = json.loads(raw)
        for it in items:
            it["query"] = query
        return items
    except Exception as e:
        print(f"WARN: {script}: {e}", file=sys.stderr)
        return []


def extract_urls_orio(urls: list[str]) -> dict[str, str]:
    if not urls:
        return {}
    try:
        data = post("/extract", {"api_key": API_KEY, "urls": urls}, timeout=120)
    except Exception as e:
        print(f"WARN: orio extract failed: {e}", file=sys.stderr)
        return {}
    out = data.get("results") or data.get("documents") or []
    if isinstance(out, dict):
        out = out.get("results", [])
    by_url = {}
    for doc in out if isinstance(out, list) else []:
        u = (doc.get("url") or doc.get("source_url") or "").strip()
        if u:
            by_url[u] = (doc.get("raw_content") or doc.get("content") or "")[:MAX_TEXT]
    return by_url


def extract_urls_cascade(urls: list[str]) -> dict[str, dict]:
    if not urls:
        return {}
    cascade_path = os.path.join(SCRIPT_DIR, "extract_cascade.py")
    if not os.path.isfile(cascade_path):
        cascade_path = os.path.join(
            os.path.dirname(os.path.dirname(SCRIPT_DIR)), "research-memory", "extract_cascade.py"
        )
    import importlib.util
    spec = importlib.util.spec_from_file_location("extract_cascade", cascade_path)
    mod = importlib.util.module_from_spec(spec)
    sys.modules["extract_cascade"] = mod
    spec.loader.exec_module(mod)

    results: dict[str, dict] = {}
    for url in urls:
        if os.environ.get("EXTRACT_USE_ORIO", "").strip() == "1":
            orio = extract_urls_orio([url])
            text = orio.get(url, "")
            if mod.quality_ok(text):
                results[url] = {
                    "full_text": text[:MAX_TEXT],
                    "extract_tier": 0,
                    "extract_method": "orio",
                }
                continue

        try:
            r = mod.extract_urls_cascade([url])[0]
            results[url] = {
                "full_text": (r.text or "")[:MAX_TEXT],
                "extract_tier": r.tier,
                "extract_method": r.method,
                "extract_error": r.error,
            }
        except Exception as e:
            print(f"WARN: cascade failed for {url}: {e}", file=sys.stderr)
            results[url] = {
                "full_text": "",
                "extract_tier": 0,
                "extract_method": "failed",
                "extract_error": str(e),
            }
    return results


def rank_hits(hits: list[dict]) -> list[dict]:
    specialist = {"arxiv", "scholar", "github"}

    def score(h: dict) -> tuple:
        ret = h.get("retriever") or "web"
        spec_bonus = 1 if ret in specialist else 0
        snip_len = len(h.get("snippet") or "")
        return (spec_bonus, snip_len)

    return sorted(hits, key=score, reverse=True)


slug = slugify(TOPIC)
ts = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S")
out_dir = os.path.join(OUTBOX_ROOT, f"{ts}-{slug}")
os.makedirs(out_dir, exist_ok=True)

queries = plan_queries(TOPIC, sub_count)
seen_urls: set[str] = set()
all_hits: list[dict] = []

print(f">> deep-research: {TOPIC}")
print(f">> depth={DEPTH} queries={len(queries)} per_query={per_query}")
print(f">> outbox: {out_dir}")

# Phase 3 — recall prior research from OUR Supabase pgvector (not client DB)
prior_memory = run_retriever("memory-recall", TOPIC, 6)
if prior_memory:
    print(f">> memory-recall: {len(prior_memory)} prior chunk(s)")
    mem_path = os.path.join(out_dir, "prior_memory.json")
    with open(mem_path, "w") as f:
        json.dump(prior_memory, f, indent=2)

# Specialist retrievers on main topic only
spec_limit = 5 if DEPTH == "deep" else 3
for script in ("arxiv-search", "scholar-search", "github-search"):
    print(f">> {script}: {TOPIC}")
    for h in run_retriever(script, TOPIC, spec_limit):
        url = (h.get("url") or "").strip()
        if not url or url in seen_urls:
            continue
        seen_urls.add(url)
        all_hits.append(h)

for q in queries:
    print(f">> search: {q}")
    for h in search(q, per_query):
        url = h["url"]
        if url in seen_urls:
            continue
        seen_urls.add(url)
        all_hits.append(h)

all_hits = rank_hits(all_hits)
coverage = Counter(h.get("retriever") or "web" for h in all_hits)
print(f">> retriever coverage: {dict(coverage)}")

top_urls = [h["url"] for h in all_hits[: (12 if DEPTH == "deep" else 8)]]

print(f">> extracting {len(top_urls)} URL(s) via cascade (trafilatura → playwright)")
by_meta = extract_urls_cascade(top_urls)

gaps = []
tier_stats = Counter()
for hit in all_hits:
    u = hit["url"]
    ret = hit.get("retriever") or "web"
    snippet = (hit.get("snippet") or "").strip()
    if u in top_urls:
        if ret in {"arxiv", "scholar", "github"} and len(snippet) >= MIN_CHARS:
            hit["full_text"] = snippet[:MAX_TEXT]
            hit["extract_tier"] = 1
            hit["extract_method"] = "retriever_snippet"
        else:
            meta = by_meta.get(u, {})
            hit["full_text"] = meta.get("full_text", "")
            hit["extract_tier"] = meta.get("extract_tier", 0)
            hit["extract_method"] = meta.get("extract_method", "failed")
            if meta.get("extract_error"):
                hit["extract_error"] = meta["extract_error"]
        tier = hit.get("extract_tier", 0)
        tier_stats[tier if tier in (0, 1, 2) else 0] += 1
        if not (hit.get("full_text") or "").strip():
            gaps.append(u)
    else:
        hit["full_text"] = snippet[:MAX_TEXT] if len(snippet) >= MIN_CHARS else ""
        hit["extract_tier"] = 1 if hit["full_text"] else 0
        hit["extract_method"] = "retriever_snippet" if hit["full_text"] else "none"

print(f">> extract tiers: {dict(tier_stats)}")

sources_path = os.path.join(out_dir, "sources.json")
with open(sources_path, "w") as f:
    json.dump({
        "topic": TOPIC,
        "queries": queries,
        "retriever_coverage": dict(coverage),
        "sources": all_hits,
        "extract_failures": gaps,
        "extract_tier_stats": dict(tier_stats),
    }, f, indent=2)

queries_path = os.path.join(out_dir, "queries.txt")
with open(queries_path, "w") as f:
    f.write("\n".join(queries) + "\n")

lines = [
    f"# Research: {TOPIC}",
    "",
    f"Generated: {ts} UTC | depth: {DEPTH}",
    f"Local stack: OrioSearch @ {BASE}",
    f"Retriever coverage: {dict(coverage)}",
    "",
]

if prior_memory:
    lines.append("## Prior research (pgvector memory — OUR Supabase)")
    for m in prior_memory[:6]:
        sim = m.get("similarity", 0)
        lines.append(f"- [{sim:.2f}] {m.get('title') or m.get('topic') or 'untitled'} ({m.get('report_slug')})")
        txt = (m.get("chunk_text") or "")[:400]
        if txt:
            lines.append(f"  {txt}")
    lines.append("")

lines.extend([
    "## Queries",
    *[f"- {q}" for q in queries],
    "",
    f"## Sources ({len(all_hits)} unique URLs)",
])

for i, h in enumerate(all_hits[:20], 1):
    ret = h.get("retriever") or "web"
    lines.append(f"### {i}. {h.get('title') or 'Untitled'}")
    lines.append(f"- URL: {h['url']}")
    lines.append(f"- Retriever: {ret}")
    lines.append(f"- Found via: {h.get('query', '')}")
    snip = (h.get("snippet") or "").strip()
    if snip:
        lines.append(f"- Snippet: {snip[:600]}")
    body = (h.get("full_text") or "").strip()
    if body:
        tier = h.get("extract_tier", "?")
        method = h.get("extract_method", "?")
        lines.append(f"- Extract: tier {tier} ({method})")
        lines.append("")
        lines.append(body[:4000])
        if len(body) > 4000:
            lines.append("… [truncated]")
    lines.append("")

lines.append("## Gaps & conflicts")
if gaps:
    lines.append("Extract failed or empty for:")
    for u in gaps:
        lines.append(f"- {u}")
else:
    lines.append("- No extract failures on top-ranked URLs.")

lines.append("")
lines.append("## Next step")
lines.append("Run gaps-review, read gaps.json, then synthesize for Telegram with citations only from sources above.")

report_path = os.path.join(out_dir, "report.md")
with open(report_path, "w") as f:
    f.write("\n".join(lines))

print(f">> wrote {report_path}")
print(f">> wrote {sources_path}")
print(f">> sources: {len(all_hits)} | full_text: {sum(1 for h in all_hits if len((h.get('full_text') or '').strip()) >= MIN_CHARS)}")
PY

# gaps-review + memory-index at end (latest outbox dir)
export RESEARCH_OUTBOX="$OUTBOX_ROOT"
"$SCRIPT_DIR/gaps-review" || true
"$SCRIPT_DIR/memory-index" || true

# Stamp for research-gate verifier
LATEST=$(ls -td "$OUTBOX_ROOT"/[0-9]*-* 2>/dev/null | head -1 || true)
if [[ -n "$LATEST" && -f "$LATEST/sources.json" ]]; then
  echo "verified_at=$(date -u +%s)" > "$LATEST/.gate-ok"
fi

echo ">> deep-research done"
