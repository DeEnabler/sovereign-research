# Copy to .env and fill in. Never commit .env.

# --- OrioSearch (local Tavily-compatible API) ---
# Dummy key is fine when auth is disabled in config.yaml
TAVILY_API_KEY=local
TAVILY_BASE_URL=http://127.0.0.1:8000
ORIOSEARCH_URL=http://127.0.0.1:8000

# --- Hermes agent (optional) ---
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USERS=your-telegram-user-id

# --- Remote deploy only (optional) ---
# VPS_HOST=user@your-server.example
# VPS_SSH_KEY=~/.ssh/id_ed25519
