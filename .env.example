# Copy to .env — never commit .env

# --- OrioSearch (local Tavily-compatible API) ---
TAVILY_API_KEY=local
TAVILY_BASE_URL=http://127.0.0.1:8000
ORIOSEARCH_URL=http://127.0.0.1:8000

# --- Phase 3: pgvector memory (YOUR Supabase — not a client project) ---
RESEARCH_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
RESEARCH_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# OURS_DATABASE_URL=postgresql://...  # optional, for apply-schema.sh
RESEARCH_EMBED_MODEL=openai/text-embedding-3-small

S2_API_KEY=
GITHUB_TOKEN=

# --- Hermes agent (optional) ---
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USERS=your-telegram-user-id
